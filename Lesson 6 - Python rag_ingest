    elif choice == "4":
        query("What is the likelihood of nuclear escalation in the current Russia, Iran, NATO and Middle East environment? Rate 1 to 5.", "risk")
    elif choice == "5":
        query("Should the UK deploy ground forces into Iran under current conditions?", "verdict")
