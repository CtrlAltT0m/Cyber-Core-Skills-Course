def main():
    parser = argparse.ArgumentParser(description="RAG defence intel assistant")
    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("seed", help="Write default working sources")
    sub.add_parser("list", help="List current source URLs")
    sub.add_parser("ingest", help="Ingest all saved URLs")
    sub.add_parser("menu", help="Open intel menu")

    add_cmd = sub.add_parser("add", help="Add one source URL")
    add_cmd.add_argument("url")

    ask_cmd = sub.add_parser("ask", help="Ask a question")
    ask_cmd.add_argument("question")
    ask_cmd.add_argument("--mode", choices=["normal", "risk", "verdict", "brief"], default="normal")

    args = parser.parse_args()

    if args.cmd == "seed":
        seed_sources()
    elif args.cmd == "add":
        add_source(args.url)
    elif args.cmd == "list":
        list_sources()
    elif args.cmd == "ingest":
        ingest_sources(load_sources())
    elif args.cmd == "ask":
        query(args.question, args.mode)
    elif args.cmd == "menu":
        menu()


if __name__ == "__main__":
    main()
